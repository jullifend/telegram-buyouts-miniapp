# Telegram BotFather token. Не публикуйте этот токен.
BOT_TOKEN=1234567890:PASTE_REAL_TOKEN_HERE

# Публичная HTTPS-ссылка Render/хостинга без слэша в конце.
WEBAPP_URL=https://your-app.onrender.com

# Секрет для входа в админку: /admin?admin_key=...
ADMIN_KEY=change_this_admin_key

# Секрет webhook Telegram. Можно написать любые длинные буквы/цифры.
WEBHOOK_SECRET=change_this_webhook_secret

# Бронь держится 50 минут.
RESERVATION_MINUTES=50

# По умолчанию 8 артикулов, у каждого 5 мест в день.
DAILY_LIMIT_PER_PRODUCT=5

# Часовой пояс для ежедневного обновления мест после 00:00. Для Москвы оставьте Europe/Moscow.
APP_TIMEZONE=Europe/Moscow

# Ник оператора без @. Можно также заполнить/изменить в админке.
OPERATOR_USERNAME=your_username

# Для локальной разработки без Telegram initData можно поставить 1.
DEV_MODE=0

# Локальная база SQLite.
DB_PATH=./buyouts.sqlite3

# Максимальный размер загружаемого фото в байтах. 8388608 = 8 МБ.
MAX_UPLOAD_BYTES=8388608
